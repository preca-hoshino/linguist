{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/model/http/providers/**/index.ts",
    "src/model/http/users/**/index.ts",
    "tests/helpers/mock-server.ts"
  ],
  "project": ["src/**/*.ts", "tests/**/*.ts"],
  "ignore": ["copilot-api/**"],
  "rules": {
    "files": "off",
    "exports": "off",
    "types": "off",
    "nsExports": "off",
    "nsTypes": "off",
    "enumMembers": "off"
  }
}


